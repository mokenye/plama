# ================================
# SERVER ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# ================================

# Server
PORT=3000
NODE_ENV=development

# Database (Neon - free tier)
# Get from: https://neon.tech
DATABASE_URL=postgresql://username:password@ep-your-instance.us-east-2.aws.neon.tech/plama?sslmode=require

# Redis (Upstash - free tier)
# Get from: https://upstash.com
REDIS_URL=redis://default:password@your-instance.upstash.io:6379

# JWT
JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change-this-to-another-long-random-string
JWT_REFRESH_EXPIRES_IN=30d

# Client URL (for CORS)
CLIENT_URL=http://localhost:5173

# Scaling flags (set to 'true' when ready to scale)
USE_REDIS_ADAPTER=false
USE_READ_REPLICAS=false
ENABLE_CACHING=false
ENABLE_CURSORS=true

# Monitoring (Better Stack - free tier)
# Get from: https://betterstack.com
LOGTAIL_TOKEN=

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=300 #adjust to 5000 for load testing, otherwise keep at 100-300 for production

# Login rate limiting
LOGIN_RATE_LIMIT_WINDOW_MS=900000 # 15 minutes
LOGIN_RATE_LIMIT_MAX_REQUESTS=10 # Only 10 login attempts per 15 mins

# Google OAuth
GOOGLE_CLIENT_ID=