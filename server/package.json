{
  "name": "plama-server",
  "version": "1.0.0",
  "description": "Real-time collaborative Kanban board - Backend",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "jest",
    "test:smoke": "jest --config jest.config.cjs --runInBand",
    "test:load": "artillery run ../artillery-test.yml",
    "db:migrate": "ts-node src/db/migrate.ts",
    "db:seed": "ts-node scripts/seed-demo.ts",
    "test:load:local": "artillery run ../artillery-local-bypass.yml"
  },
  "dependencies": {
    "@types/express-serve-static-core": "^4.17.43",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-rate-limit": "^7.2.0",
    "google-auth-library": "^10.6.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.11.3",
    "pino": "^8.19.0",
    "pino-pretty": "^11.0.0",
    "prom-client": "^15.1.3",
    "redis": "^4.6.13",
    "socket.io": "^4.7.4",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^24.0.0",
    "@types/pg": "^8.11.2",
    "artillery": "^2.0.17",
    "axios": "^1.6.8",
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "socket.io-client": "^4.7.4",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.3"
  }
}
