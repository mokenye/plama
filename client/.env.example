# ================================
# CLIENT ENVIRONMENT VARIABLES
# Copy to .env and fill in your values
# ================================

# API URL (leave empty to use Vite proxy in development)
VITE_API_URL=

# Google OAuth Client ID (leave empty to disable Google login)
VITE_GOOGLE_CLIENT_ID= 

# In production, set to your deployed backend URL:
# VITE_API_URL=https://plama-api.northflank.com